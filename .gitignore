# --- Superseedr Config ---
# Ignore the local environment file
.env


# --- local temp---
tmp
*.tmp

# --- macOS ---
.DS_Store

# --- Editor Specific ---
# Ignore VSCode workspace settings
.vscode/

# --- Rust / Cargo ---
# Ignore build artifacts
/target/
rust-toolchain

# --- VPN Credentials ---
# Block these sensitive filenames ANYWHERE they appear
.gluetun.env

# BUT, explicitly UN-ignore (with '!') the template files
!.gluetun.env.example

# --- Safety Net ---
# Ignore common torrent/media files ANYWHERE in the repo
# in case of accidental downloads to the project root.
*.mkv
*.mp4
*.avi
*.mov
*.flv
*.iso
*.img
*.zip
*.rar
*.7z
*.tar
*.gz
*.nfo

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
.eggs/
dist/
build/
*.egg

# --- Integration Tests ---
# Test data directories (generated during tests)
integration_tests/__pycache__/
integration_tests/src/__pycache__/
integration_tests/data/generated/
integration_tests/data/superseedr_watch/
integration_tests/data/superseedr_downloads/
integration_tests/data/superseedr_status/
integration_tests/data/reference_client_downloads/
integration_tests/data/tracker_data/
integration_tests/data/qbittorrent_config/
integration_tests/data/transmission_config/
integration_tests/data/transmission_watch/
integration_tests/data/test_data/
integration_tests/artifacts/
integration_tests/torrents/*.torrent
!integration_tests/torrents/*.torrent.example
